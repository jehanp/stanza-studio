# GitHub PAT with Copilot Models access (required for AI features)
GITHUB_TOKEN=

# SQLite database file path (default: ./stanza.db relative to the app/ directory)
DATABASE_PATH=

# Path to the lyrics directory (default: ../lyrics relative to the app/ directory)
LYRICS_PATH=

# Suno integration — choose one of the options below:

# Option A: Self-hosted gcui-art/suno-api Docker container (recommended)
# docker run -d -p 3000:3000 -e SUNO_COOKIE=<your-cookie> gcui/suno-api
SUNO_API_URL=http://localhost:3000

# Option B: Direct Suno cookie (used only if SUNO_API_URL is not set)
SUNO_COOKIE=

# GitHub Models default model — gpt-4o is free with Copilot
GITHUB_MODELS_MODEL=gpt-4o
